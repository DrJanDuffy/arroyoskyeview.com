# Get your v0 API key here: https://v0.dev/chat/settings/keys
V0_API_KEY="your_v0_api_key"

# Search Console / Webmaster verification tags (meta verification tokens, not analytics IDs)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_search_console_token
NEXT_PUBLIC_BING_SITE_VERIFICATION=your_bing_webmaster_token

# RealScout office listings (root layout loads widgets/realscout-web-components.umd.js).
# Optional overrides — see lib/realscout-config.ts for defaults.
# NEXT_PUBLIC_REALSCOUT_AGENT_ENCODED_ID=
# NEXT_PUBLIC_REALSCOUT_OFFICE_SORT_ORDER=
# NEXT_PUBLIC_REALSCOUT_OFFICE_LISTING_STATUS=
# NEXT_PUBLIC_REALSCOUT_OFFICE_PROPERTY_TYPES=
# NEXT_PUBLIC_REALSCOUT_OFFICE_PRICE_MIN=
# NEXT_PUBLIC_REALSCOUT_OFFICE_PRICE_MAX=
#
# Code (not env): when adding RealScoutOfficePriceBands to a new route, add that
# pathname to REALSCOUT_PRICE_BANDS_ROUTE_PATHS in lib/realscout-config.ts so the
# footer does not duplicate MLS embeds.

# Optional: for rate limiting
KV_REST_API_URL=your_upstash_redis_rest_url
KV_REST_API_TOKEN=your_upstash_redis_rest_token

# Optional: server-side URL indexing submission (IndexNow).
# Keep these values only in Vercel env, never client-side code.
INDEXING_ENABLED=false
INDEXNOW_KEY=your_indexnow_key
# Default mode: app/[indexnowKey].txt/route.ts serves https://www.arroyoskyeview.com/{INDEXNOW_KEY}.txt
# Optional override mode: set INDEXNOW_KEY_LOCATION (or send keyLocation in request body).
INDEXNOW_KEY_LOCATION=https://www.arroyoskyeview.com/your_indexnow_key.txt
INDEXING_API_BASE_URL=https://api.indexnow.org/indexnow
INDEXING_ALLOWED_HOSTS=www.arroyoskyeview.com
INDEXING_MAX_URLS_PER_SUBMISSION=1000

# Secret used by /api/indexing/submit. Send either:
# - Authorization: Bearer <INDEXING_WEBHOOK_SECRET>
# - x-indexing-secret: <INDEXING_WEBHOOK_SECRET>
INDEXING_WEBHOOK_SECRET=your_strong_random_secret
